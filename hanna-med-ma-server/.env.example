# ─── Server ──────────────────────────────────────────────────
SERVER_NODE_ENV=production
SERVER_PORT=3002
SERVER_DATABASE_URL=postgresql://user:password@host:5432/database?schema=public
SERVER_JWT_SECRET=your-jwt-secret
SERVER_CREDENTIALS_ENCRYPTION_KEY=your-32-char-encryption-key
SERVER_API_KEY=your-api-key
SERVER_REDIS_URL=redis://localhost:6379

# ─── AI / LLM ────────────────────────────────────────────────
# Gemini 2.5 Flash — powers the doctor-chat Router agent + the
# Gemini embedding pipeline that feeds the regulatory vector store.
SERVER_GEMINI_API_KEY=your-gemini-api-key
# Claude Sonnet 4.6 — powers the AI Coder agent (Phase 1 billing brain).
SERVER_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ─── Firebase Admin SDK (push notifications) ─────────────────
SERVER_FIREBASE_PROJECT_ID=your-firebase-project-id
SERVER_FIREBASE_CLIENT_EMAIL=your-firebase-client-email
SERVER_FIREBASE_PRIVATE_KEY=your-base64-encoded-private-key

# ─── S3 (face sheets + provider notes) ───────────────────────
SERVER_AWS_REGION=us-east-2
SERVER_AWS_ACCESS_KEY_ID=your-aws-access-key-id
SERVER_AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
SERVER_AWS_S3_BUCKET=hannamed-ma
# TTL (seconds) for presigned URLs on face sheets / notes.
SERVER_AWS_PRESIGNED_TTL=3600
