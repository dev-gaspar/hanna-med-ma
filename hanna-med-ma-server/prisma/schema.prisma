// Hanna-Med MA V2 — Prisma Schema
// Architecture: Multi-Agent System (Gemini-powered)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SERVER_DATABASE_URL")
}

// ─── Doctor ─────────────────────────────────────────────────

model Doctor {
  id          Int      @id @default(autoincrement())
  name        String
  username    String   @unique
  password    String
  // `specialty` is kept as a plain string for back-compat with every
  // legacy caller (chat prompts, RPA, auth login). The SOURCE OF TRUTH
  // is specialtyId → Specialty. The string is kept in sync with
  // specialtyRel.name by seed scripts / admin writes.
  specialty   String?
  specialtyId Int?
  // Practice grouping — doctors in the same practice share workflow
  // conventions (billing/biller behaviors, ICD ranking caps, modifier
  // timing conventions) which live in `Practice.systemPrompt` and are
  // appended to the coder prompt as a third layer (after specialty).
  practiceId  Int?
  emrSystems  String[] @default([]) // EMR systems this doctor uses: ["JACKSON", "STEWARD", "BAPTIST"]

  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specialtyRel Specialty? @relation(fields: [specialtyId], references: [id])
  practice     Practice?  @relation(fields: [practiceId], references: [id])

  // EMR Credentials (only for systems that need them)
  credentials DoctorCredential[]

  // AI Chat
  chatSession ChatSession?

  // FCM Push Notifications
  fcmTokens DoctorFcmToken[]

  // RPA Nodes assigned to this doctor
  rpaNodes RpaNode[]

  // Patient census links (many-to-many)
  patientLinks DoctorPatient[]

  // Encounters (doctor saw patient)
  encounters Encounter[]

  @@map("doctors")
}

// ─── FCM Push Notification Tokens ───────────────────────────

model DoctorFcmToken {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  token     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_fcm_tokens")
}

// ─── EMR Credentials ────────────────────────────────────────

enum SystemKey {
  JACKSON
  STEWARD
  BAPTIST
}

model DoctorCredential {
  id        Int       @id @default(autoincrement())
  doctorId  Int
  systemKey SystemKey
  fields    Json // Encrypted: {"username": "...", "password": "..."}
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, systemKey])
  @@map("doctor_credentials")
}

// ─── Admin Users ────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  rol       String
  username  String   @unique
  password  String
  email     String   @unique
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─── RPA Nodes (Plug & Play) ────────────────────────────────

enum RpaNodeStatus {
  PENDING
  ACTIVE
  OFFLINE
  DISABLED
}

model RpaNode {
  id        Int           @id @default(autoincrement())
  uuid      String        @unique
  hostname  String?
  status    RpaNodeStatus @default(PENDING)
  doctorId  Int?
  lastSeen  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  doctor Doctor? @relation(fields: [doctorId], references: [id])

  @@map("rpa_nodes")
}

// ─── Chat ───────────────────────────────────────────────────

enum MessageRole {
  USER
  ASSISTANT
}

enum MessageType {
  TEXT
  PATIENT_LIST
  PATIENT_SUMMARY
  BATCH_PATIENT_SUMMARY
  PATIENT_INSURANCE
  BATCH_PATIENT_INSURANCE
  PATIENT_LAB
  BATCH_PATIENT_LAB
  ERROR
}

model ChatSession {
  id        Int       @id @default(autoincrement())
  doctorId  Int       @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@map("chat_sessions")
}

model Message {
  id        Int         @id @default(autoincrement())
  sessionId Int
  role      MessageRole
  content   String      @db.Text
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Patients (EMR Data) ────────────────────────────────────

enum EmrSystem {
  JACKSON
  STEWARD
  BAPTIST
}

enum BillingEmrStatus {
  PENDING
  REGISTERED
  ALREADY_EXISTS
  FAILED
}

model Patient {
  id                  Int              @id @default(autoincrement())
  emrSystem           EmrSystem
  name                String
  normalizedName      String
  location            String?
  facility            String?          // Sub-hospital for multi-facility EMRs (e.g., Baptist sub-hospitals)
  reason              String?
  admittedDate        String?
  billingEmrStatus    BillingEmrStatus @default(PENDING)
  billingEmrPatientId String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  rawData     PatientRawData[]
  doctorLinks DoctorPatient[]
  encounters  Encounter[]

  @@unique([emrSystem, normalizedName])
  @@index([emrSystem])
  @@map("patients")
}

// ─── Doctor–Patient Census Link (many-to-many) ─────────────

model DoctorPatient {
  id         Int      @id @default(autoincrement())
  doctorId   Int
  patientId  Int
  isActive   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([doctorId, patientId])
  @@index([doctorId, isActive])
  @@map("doctor_patients")
}

// ─── Encounters (Doctor saw Patient) ────────────────────────

enum EncounterType {
  CONSULT   // First visit during admission — Consult Note
  PROGRESS  // Follow-up visits — Progress Note
  PROCEDURE // Surgical / bedside procedure visit — operative or procedure note (CPT 1xxxx-7xxxx is primary, no E/M family applies)
}

enum NoteStatus {
  PENDING         // Waiting for first attempt (4h after seen)
  SEARCHING       // RPA attempt in progress
  NOT_FOUND       // Attempt done; no matching note found (terminal if noteAttempts >= 6)
  FOUND_UNSIGNED  // Note found on target date but not signed yet (terminal if noteAttempts >= 6)
  FOUND_SIGNED    // Success: signed note uploaded and providerNote populated
}

model Encounter {
  id                Int           @id @default(autoincrement())
  patientId         Int
  doctorId          Int
  type              EncounterType @default(CONSULT)
  dateOfService     DateTime      @default(now())
  deadline          DateTime?     // 24h window for clinical note collection
  faceSheet         String?       // S3 key of the insurance face sheet PDF (copied from latest INSURANCE raw data at seen-time)
  providerNote      String?       // S3 key of the provider note PDF (set when noteStatus=FOUND_SIGNED)
  noteStatus        NoteStatus    @default(PENDING)
  noteAttempts      Int           @default(0)
  noteLastAttemptAt DateTime?
  noteAgentSummary  String?       @db.Text  // Full narrative of what the agent did on the last attempt
  // CMS Place of Service code captured at "Mark as seen" time. The
  // doctor knows where the patient was actually seen better than any
  // OCR of the face sheet, so we ask in the encounter modal. Common
  // values: "11" office, "21" inpatient hospital, "22" outpatient
  // hospital, "23" emergency room, "24" ASC, "31" SNF, "12" home.
  // Drives MPFS facility-vs-non-facility pricing in the AI Coder.
  // Nullable for legacy encounters created before this column existed.
  placeOfService    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  codings EncounterCoding[]

  @@index([doctorId])
  @@index([patientId])
  @@index([noteStatus])
  @@map("encounters")
}

// ─── AI Coder proposals per encounter ───────────────────────
//
// One row per "pass" of the AI Coder — regenerate creates a new
// DRAFT. The provider/coder reviews and transitions to APPROVED
// (sign-off) → TRANSFERRED_TO_CARETRACKER (Hajira tipéa a mano).
// Kept separately from Encounter so history is preserved even
// after approvals/denials.

enum EncounterCodingStatus {
  IN_PROGRESS
  DRAFT
  UNDER_REVIEW
  APPROVED
  TRANSFERRED_TO_CARETRACKER
  DENIED
  FAILED
}

enum NoteVersionBasis {
  DRAFT
  SIGNED
}

model EncounterCoding {
  id                Int                  @id @default(autoincrement())
  encounterId       Int
  status            EncounterCodingStatus @default(IN_PROGRESS)
  basedOnNoteVersion NoteVersionBasis    @default(SIGNED)

  // Full proposal JSON as emitted by the CoderAgent's finalize_coding tool.
  // Keeping it verbatim lets us render the same panel later without
  // re-running the agent and without serialising into many columns.
  // Null while status=IN_PROGRESS (no proposal yet).
  proposal          Json?

  // Flattened metrics for fast filtering/sorting in the coder inbox.
  primaryCpt        String?
  auditRiskScore    Int?                  // 0-100
  riskBand          String?               // "LOW" | "REVIEW" | "RISK"
  toolCallCount     Int?
  runDurationMs     Int?

  // Live reasoning log — array of events the agent emits during the run.
  // Kept in the same row so polling a single coding returns everything.
  // Each element: { ts, type: "think"|"tool_call"|"tool_result", ... }
  reasoningLog      Json?

  // Populated when status=FAILED. Short human-readable reason.
  errorMessage      String?

  // Lifecycle timestamps — useful for "running for 2m 14s" in the UI.
  startedAt         DateTime?
  completedAt       DateTime?

  // Sign-off audit trail.
  approvedByDoctorId Int?
  approvedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
  @@index([status])
  @@map("encounter_codings")
}

// ─── Patient Raw Data (Summaries, Insurance, Lab Results) ───

enum RawDataType {
  SUMMARY
  INSURANCE
  LAB
}

model PatientRawData {
  id          Int         @id @default(autoincrement())
  patientId   Int
  dataType    RawDataType
  rawContent  String      @db.Text
  file        String?
  extractedAt DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, dataType])
  @@map("patient_raw_data")
}

// ─── Coverage / Regulatory Engine ───────────────────────────
// The regulatory "brain" the AI Coder queries to propose codes,
// price them, and flag audit risk. Populated from four CMS sources:
//
//   MPFS        — per-CPT localized payment     (FeeScheduleItem + Locality)
//   NCCI PTP    — CPT pairs that bundle         (NcciEdit)
//   MUE         — max units per CPT per day     (MueLimit)
//   LCD + Art.  — local coverage rules + CPT/ICD crosswalks
//                 (Lcd, LcdContractor, LcdArticle, LcdArticleContractor,
//                  LcdArticleLink, LcdArticleCpt, LcdArticleIcd10)

// Medicare GPCI locality. A locality bundles the three GPCIs
// (work / practice expense / malpractice) that localize the
// national RVUs into a regional payment amount.
// Florida Locality 04 = Miami-Dade, MAC = First Coast (FCSO).
model Locality {
  id            Int     @id @default(autoincrement())
  code          String  // e.g., "04"
  state         String  // e.g., "FL"
  macContractor String? // e.g., "First Coast (FCSO)"
  description   String? // e.g., "Miami, FL"
  workGpci      Float
  peGpci        Float
  mpGpci        Float
  year          Int

  feeScheduleItems FeeScheduleItem[]

  @@unique([code, state, year])
  @@map("localities")
}

// One row of the localized Medicare Physician Fee Schedule:
// one CPT (+ optional modifier) at one locality for one year.
// amountUsd is pre-computed from RVUs × GPCIs × conversion factor
// so lookups are a single PK hit.
model FeeScheduleItem {
  id                Int     @id @default(autoincrement())
  cpt               String
  modifier          String  @default("") // "" when no modifier, or e.g., "26" professional, "TC" technical
  year              Int
  localityId        Int
  description       String?

  workRvu           Float
  peRvu             Float   // non-facility practice expense
  peFacilityRvu     Float?  // facility practice expense (site-of-service alternative)
  mpRvu             Float
  conversionFactor  Float
  amountUsd         Float   // non-facility payment
  amountFacilityUsd Float?  // facility payment (when peFacilityRvu present)

  globalDays        String? // "000" | "010" | "090" | "MMM" | "XXX" | "YYY" | "ZZZ"
  statusCode        String? // CMS status indicator (A=active, R=restricted, I=invalid, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locality Locality @relation(fields: [localityId], references: [id], onDelete: Cascade)

  @@unique([cpt, modifier, localityId, year])
  @@index([cpt, year])
  @@map("fee_schedule_items")
}

// NCCI PTP (Procedure-to-Procedure) edit: a pair of codes that
// bundle into one. modifierIndicator tells us whether a proper
// modifier (59, XE, XP, XS, XU, ...) can unbundle the pair:
//   "0" = never allowed, "1" = allowed with modifier, "9" = N/A.
model NcciEdit {
  id                Int       @id @default(autoincrement())
  column1Cpt        String    // comprehensive code
  column2Cpt        String    // component code
  priorTo1996       Boolean   @default(false)
  effectiveDate     DateTime
  deletionDate      DateTime? // null = still active
  modifierIndicator String    // "0" | "1" | "9"
  rationale         String?   @db.Text
  editType          String    // "PRACTITIONER" | "HOSPITAL"
  quarter           String    // "2026Q2"

  createdAt DateTime @default(now())

  // CMS keeps historical snapshots in the same quarterly release so
  // the "current" edit and its prior revisions all land here. Query
  // with `deletionDate IS NULL` to get the currently-enforced pair.
  @@index([column1Cpt, deletionDate])
  @@index([column2Cpt, deletionDate])
  @@index([column1Cpt, column2Cpt, editType])
  @@map("ncci_edits")
}

// Medically Unlikely Edit: max units of a CPT billable in one day.
// mai is the adjudication indicator (1=Line, 2=DOS absolute, 3=DOS per beneficiary).
model MueLimit {
  id                    Int      @id @default(autoincrement())
  cpt                   String
  mueValue              Int
  adjudicationIndicator String   // raw "N Description: Subcategory"
  mai                   String   // extracted "1" | "2" | "3"
  rationale             String?
  serviceType           String   // "PRACTITIONER" | "OUTPATIENT" | "DME"
  effectiveDate         DateTime

  createdAt DateTime @default(now())

  @@unique([cpt, serviceType, effectiveDate])
  @@index([cpt])
  @@map("mue_limits")
}

// Local Coverage Determination document. The free-text fields come
// from CMS as HTML — we persist both the raw HTML and a plain-text
// variant so future vector embeddings can index the stripped copy.
model Lcd {
  id                      Int       @id @default(autoincrement())
  lcdId                   String    // e.g., "33252"
  version                 Int
  title                   String    @db.Text
  displayId               String?
  status                  String?
  origEffectiveDate       DateTime?
  revEffectiveDate        DateTime?
  lastUpdated             DateTime?
  mcdPublishDate          DateTime?

  indication              String?   @db.Text
  indicationPlain         String?   @db.Text
  codingGuidelines        String?   @db.Text
  codingGuidelinesPlain   String?   @db.Text
  docReqs                 String?   @db.Text
  docReqsPlain            String?   @db.Text
  utilGuide               String?   @db.Text
  utilGuidePlain          String?   @db.Text
  summaryOfEvidence       String?   @db.Text
  summaryOfEvidencePlain  String?   @db.Text
  analysisOfEvidence      String?   @db.Text
  analysisOfEvidencePlain String?   @db.Text
  diagnosesSupport        String?   @db.Text
  diagnosesSupportPlain   String?   @db.Text
  bibliography            String?   @db.Text
  bibliographyPlain       String?   @db.Text
  keywords                String?   @db.Text

  contractors  LcdContractor[]
  articleLinks LcdArticleLink[]
  textChunks   LcdTextChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lcdId, version])
  @@index([status])
  @@map("lcds")
}

// Which MACs an LCD applies to. Filter by contractorNumber "09102"
// for First Coast Part B Florida.
model LcdContractor {
  id               Int     @id @default(autoincrement())
  lcdId            Int
  contractorNumber String
  contractorName   String?
  jurisdiction     String?

  lcd Lcd @relation(fields: [lcdId], references: [id], onDelete: Cascade)

  @@unique([lcdId, contractorNumber])
  @@index([contractorNumber])
  @@map("lcd_contractors")
}

// MCD Billing & Coding Article — where the CPT/ICD crosswalks live
// since CMS moved them out of LCDs around 2019. One LCD typically
// has one companion B&C article reachable via LcdArticleLink.
model LcdArticle {
  id                    Int       @id @default(autoincrement())
  articleId             String    // e.g., "52369"
  version               Int
  title                 String    @db.Text
  articleType           String?
  displayId             String?
  status                String?
  origEffectiveDate     DateTime?
  revEffectiveDate      DateTime?
  lastUpdated           DateTime?

  description           String?   @db.Text
  descriptionPlain      String?   @db.Text
  otherComments         String?   @db.Text
  otherCommentsPlain    String?   @db.Text

  contractors  LcdArticleContractor[]
  cptCodes     LcdArticleCpt[]
  icd10Codes   LcdArticleIcd10[]
  lcdLinks     LcdArticleLink[]
  textChunks   LcdTextChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([articleId, version])
  @@map("lcd_articles")
}

model LcdArticleContractor {
  id               Int     @id @default(autoincrement())
  articleId        Int
  contractorNumber String
  contractorName   String?
  jurisdiction     String?

  article LcdArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, contractorNumber])
  @@index([contractorNumber])
  @@map("lcd_article_contractors")
}

model LcdArticleLink {
  id        Int @id @default(autoincrement())
  lcdId     Int
  articleId Int

  lcd     Lcd        @relation(fields: [lcdId], references: [id], onDelete: Cascade)
  article LcdArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([lcdId, articleId])
  @@map("lcd_article_links")
}

model LcdArticleCpt {
  id          Int     @id @default(autoincrement())
  articleId   Int
  cpt         String
  description String? @db.Text
  sequence    Int?

  article LcdArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([cpt])
  @@index([articleId])
  @@map("lcd_article_cpts")
}

model LcdArticleIcd10 {
  id          Int     @id @default(autoincrement())
  articleId   Int
  icd10       String
  coverage    String // "COVERED" | "NONCOVERED"
  description String? @db.Text

  article LcdArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([icd10])
  @@index([articleId, coverage])
  @@map("lcd_article_icd10s")
}

// ─── Vector / semantic search layer ────────────────────────
// All embeddings live in three tables with `vector(768)` columns
// (gemini text-embedding-004 native size, well within pgvector's
// 2000-dim HNSW cap). One row per unique code — NOT per localized
// MPFS row or per Article crosswalk — so there's no duplication.

// Full ICD-10-CM 2026 catalog. The only catalog we ingest that
// wasn't already in the DB — CPT descriptions live in
// fee_schedule_items / lcd_article_cpts, which the embedder
// reads directly.
model Icd10Code {
  id               Int                           @id @default(autoincrement())
  code             String                        @unique // e.g., "E11.621"
  orderNumber      Int
  isBillable       Boolean
  shortDescription String                        @db.Text
  longDescription  String                        @db.Text
  embedding        Unsupported("vector(768)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("icd10_codes")
}

// Deduplicated CPT/HCPCS catalog with embeddings. Fed by the
// union of fee_schedule_items + lcd_article_cpts so every code
// the AI could possibly cite is searchable.
model CptCode {
  id              Int                           @id @default(autoincrement())
  code            String                        @unique
  description     String                        @db.Text
  longDescription String?                       @db.Text
  statusCode      String?
  embedding       Unsupported("vector(768)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cpt_codes")
}

// Specialty catalog + per-specialty prompt delta for the AI Coder.
// Doctors link here via Doctor.specialtyId. The systemPrompt field
// is appended to the coder's base prompt at runtime (teaches exam
// scope, code preferences, LCD anchors without polluting the base).
model Specialty {
  id           Int      @id @default(autoincrement())
  name         String   @unique // canonical display name, e.g. "Podiatry"
  systemPrompt String   @db.Text @default("")

  // Place-of-service config — drives the doctor-facing encounter
  // modal. `commonPosCodes` is the ordered list of POS codes shown
  // as quick-pick buttons (each entry must reference a row in
  // `place_of_service_codes`); `defaultPosCode` is the one
  // pre-selected when the modal opens. Empty array → no shortcuts,
  // doctor picks from the full CMS list. Null `defaultPosCode` →
  // no pre-fill. Both editable from the admin UI per specialty.
  commonPosCodes  String[] @default([])
  defaultPosCode  String?

  doctors Doctor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("specialties")
}

// CMS Place-of-Service code catalog. Sourced from the official CMS
// POS code set (https://www.cms.gov/Medicare/Coding/place-of-service-codes/Place_of_Service_Code_Set).
// One row per code; `active=false` retires a code without deleting
// historical encounter rows that reference it. The `shortLabel`
// column exists so the UI can render compact buttons; the canonical
// `name` is what claims/audits show.
model PlaceOfServiceCode {
  code        String  @id // "11", "21", "22", "31", ...
  name        String  // "Office", "Inpatient Hospital"
  shortLabel  String  // "Office", "Inpatient" — fits a 110px button
  description String  @db.Text
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("place_of_service_codes")
}

// Practice catalog + per-practice convention delta for the AI Coder.
// Doctors link here via Doctor.practiceId. The systemPrompt field
// captures workflow conventions that are SPECIFIC to this practice
// group: billing/biller behaviors, ICD ranking caps, modifier timing
// conventions, principal-dx overrides, etc. Specialty-agnostic; would
// differ between practices. Appended after the specialty delta as a
// third layer of prompt assembly.
//
// Three layers of cache_control let Anthropic's prompt cache reuse:
//   - base prompt: across ALL encounters
//   - specialty delta: across encounters of the same specialty
//   - practice convention delta: across encounters of the same practice
model Practice {
  id           Int      @id @default(autoincrement())
  name         String   @unique // canonical display name, e.g. "Hanna Med Podiatry & Vascular"
  systemPrompt String   @db.Text @default("")

  // Medicare administrative geography for this practice. The CMS
  // GPCI locality drives MPFS pricing; the MAC contractor number
  // drives which LCDs/articles are in jurisdiction. Both move
  // together when a practice opens in a new state — keeping them
  // on Practice means a new doctor in the same practice inherits
  // the right values without per-encounter input. Defaults below
  // are the Hanna-Med values (Miami-Dade + First Coast FL Part B).
  medicareLocality         String  @default("04")
  medicareContractorNumber String  @default("09102")

  doctors    Doctor[]
  payerRules PayerEMRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("practices")
}

enum PayerEMCategory {
  ALWAYS_INITIAL_HOSPITAL // 99221-99223 family forced
  ALWAYS_CONSULT          // 99253-99255 family forced
  DEPENDS_HUMAN_REVIEW    // flag in audit notes; default to ALWAYS_INITIAL
}

// Per-payer E/M family selection rule. Resolution order:
//   1) practice-specific (practiceId = doctor.practiceId, age in [ageMin, ageMax])
//   2) global default     (practiceId IS NULL, age in [ageMin, ageMax])
//   3) DEPENDS_HUMAN_REVIEW fallback if no row matches
//
// Self-Pay age cutoff is encoded as TWO rows for the same payerName:
//   payerName="Self Pay", ageMin=null,  ageMax=64,  category=ALWAYS_CONSULT
//   payerName="Self Pay", ageMin=65,    ageMax=null, category=ALWAYS_INITIAL_HOSPITAL
//
// payerPattern (optional) is a regex/glob applied against the face-sheet
// payer name when payerName itself doesn't match exactly. e.g.
// payerPattern="(?i)bcbs.*ppo" matches "BCBS PPC/PPS/PHS PPO".
model PayerEMRule {
  id           Int             @id @default(autoincrement())
  payerName    String
  payerPattern String?
  category     PayerEMCategory
  ageMin       Int?            // null = no lower bound
  ageMax       Int?            // null = no upper bound
  practiceId   Int?            // null = global default
  practice     Practice?       @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  notes        String?         @db.Text
  source       String?         // provenance, e.g. "Hajira 2026-04-27 calibration doc"
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([payerName, practiceId, ageMin])
  @@index([category])
  @@index([payerName])
  @@map("payer_em_rules")
}

// Chunked ICD-10-CM Official Guidelines for Coding and Reporting.
// Authoritative source for WHEN to combine codes, WHICH code pairs
// are mandated by CMS, sequencing rules, etc. The CoderAgent queries
// this via search_coding_guidelines to ground its specificity
// decisions in the actual guideline text (not just the prompt).
model CodingGuideline {
  id          Int                           @id @default(autoincrement())
  sourceYear  Int                           // e.g., 2026
  section     String                        // e.g., "I.C.4.a.2" or "Section IV.B"
  heading     String?                       // e.g., "Diabetes mellitus"
  chunkIndex  Int
  text        String                        @db.Text
  embedding   Unsupported("vector(768)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceYear, section])
  @@map("coding_guidelines")
}

// Authoritative CMS policy prose — Medicare Claims Processing
// Manual (billing/consult-code/modifier rules), NCCI Policy Manual
// (bundling narrative, NOT the per-pair edits in ncci_edits), and
// the Global Surgery Booklet (global-period definitions).
//
// These three sources share a shape (heading-structured prose with
// stable citation anchors) so they live in one table with a `kind`
// discriminator. The agent queries them via search_policy_rules —
// they answer the "WHY is this the right code/modifier?" class of
// question that per-code tables (CptCode, NcciEdit, MueLimit)
// cannot.
//
// ICD-10-CM Official Guidelines use a separate table
// (CodingGuideline) because they already had one before this was
// added, and their section naming ("I.C.4.a.2") is idiosyncratic
// enough that keeping their own schema field is cleaner.
enum PolicyDocKind {
  CMS_CLAIMS_MANUAL        // Medicare Claims Processing Manual, Pub 100-04 (Ch.12 etc.)
  NCCI_POLICY_MANUAL       // National Correct Coding Initiative Policy Manual (prose)
  GLOBAL_SURGERY_BOOKLET   // MLN Booklet 907166 — Global Surgery
}

model PolicyRule {
  id            Int                           @id @default(autoincrement())
  kind          PolicyDocKind
  // Authoritative citation the agent should quote back, e.g.
  //   "CMS Claims Processing Manual Ch.12 §30.6.10"
  //   "NCCI Policy Manual Ch.1 Section E"
  //   "MLN 907166 — Global Surgery"
  citation      String
  sourceUrl     String?                       // link back to cms.gov
  sourceVersion String?                       // "Rev. 12345 (2024-09-26)" or "2026 edition"
  chapter       String?                       // "Chapter 12" / "Chapter 1"
  section       String?                       // "30.6.10" / "E" / "Global Period"
  heading       String?                       // subheading captured from the PDF
  chunkIndex    Int
  text          String                        @db.Text
  embedding     Unsupported("vector(768)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, section])
  @@map("policy_rules")
}

// Chunked free-text sections of LCDs and Articles so an LCD's
// coverage rationale can be searched semantically. One row per
// ~500-token slice; chunking is lossy on purpose (embedding a 40k-
// token LCD as one vector loses granularity).
model LcdTextChunk {
  id         Int                           @id @default(autoincrement())
  lcdId      Int?
  articleId  Int?
  section    String // "indication" | "codingGuidelines" | "description" | ...
  chunkIndex Int
  text       String                        @db.Text
  embedding  Unsupported("vector(768)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lcd     Lcd?        @relation(fields: [lcdId], references: [id], onDelete: Cascade)
  article LcdArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([lcdId, section])
  @@index([articleId, section])
  @@map("lcd_text_chunks")
}
